# Optional. When both are set, Twitch is checked for real via the Helix API.
# Without them, Twitch results are reported as "unknown".
# Create an app at https://dev.twitch.tv/console/apps to get these.
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Public Stripe Payment Links. Paste links from your Stripe dashboard here.
# These are safe NEXT_PUBLIC values; do not add secret Stripe API keys.
NEXT_PUBLIC_STRIPE_PRO_PAYMENT_LINK=
NEXT_PUBLIC_STRIPE_BUSINESS_PAYMENT_LINK=
